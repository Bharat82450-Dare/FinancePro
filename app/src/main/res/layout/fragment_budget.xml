<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Gradient header zone with title -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:background="@drawable/gradient_header_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="52dp"
                android:text="Budget"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:fontFamily="sans-serif-black" />
        </FrameLayout>

        <!-- Header title overlaps gradient via negative margin on card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-44dp"
            android:background="@drawable/clay_card_bg"
            android:elevation="12dp"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly Budgets"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary" />

            <!-- Overall budget card contents -->
            <LinearLayout
                android:id="@+id/overallBudgetCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/neo_inset_bg"
                android:orientation="vertical"
                android:padding="@dimen/card_padding_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="MONTHLY TARGET"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/btnSetTarget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Set Target"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/pill_bg"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/noTargetText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Tap 'Set Target' to define your monthly spending limit"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:visibility="visible" />

                <LinearLayout
                    android:id="@+id/targetSetGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/totalSpentText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="₹0"
                            android:textColor="@color/primary"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/totalLimitText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="of ₹10,000"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:gravity="end" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/overallProgressBar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/progress_height"
                        android:layout_marginTop="10dp"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/surface_variant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remaining"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/remainingText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹10,000"
                                android:textColor="@color/income"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-black" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Projected"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/projectedText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹—"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-black" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- UPI Auto-Track Toggle Card -->
        <LinearLayout
            android:id="@+id/smsTrackCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/clay_card_bg"
            android:elevation="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/card_padding_sm">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPI Auto-Track"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-detect bank SMS to log UPI transactions"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/smsTrackSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Category Budgets label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category Budgets"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/budgetRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp" />

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="No category budgets yet.\nTap + to set a limit per category."
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddBudget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Add Budget"
        app:backgroundTint="@color/primary"
        app:srcCompat="@drawable/ic_plus"
        app:tint="@android:color/white"
        app:elevation="@dimen/elevation_fab" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
