<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Premium gradient top zone -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/gradient_header_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHeight_percent="0.40"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lock icon -->
    <LinearLayout
        android:id="@+id/lock_icon_container"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/clay_card_bg"
        android:gravity="center"
        android:elevation="8dp"
        android:layout_marginTop="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_budget"
            app:tint="@color/primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/pin_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Enter PIN"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lock_icon_container" />

    <TextView
        android:id="@+id/pin_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Authenticate to access your finances"
        android:textColor="#BBFFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pin_title" />

    <!-- PIN indicator dots — larger, more premium -->
    <LinearLayout
        android:id="@+id/pin_indicator_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pin_subtitle">

        <View
            android:id="@+id/dot1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="10dp"
            android:background="@drawable/dot_off" />
        <View
            android:id="@+id/dot2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="10dp"
            android:background="@drawable/dot_off" />
        <View
            android:id="@+id/dot3"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="10dp"
            android:background="@drawable/dot_off" />
        <View
            android:id="@+id/dot4"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_margin="10dp"
            android:background="@drawable/dot_off" />
    </LinearLayout>

    <!-- Premium keypad with rounded key backgrounds -->
    <LinearLayout
        android:id="@+id/keypad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pin_indicator_container"
        app:layout_constraintVertical_bias="0.55">

        <!-- Row 1: 1 2 3 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="1" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="2" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="3" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 2: 4 5 6 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="4" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="5" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="6" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 3: 7 8 9 -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="7" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="8" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="9" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
        </LinearLayout>

        <!-- Row 4: biometric, 0, backspace -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <ImageButton
                    android:id="@+id/btn_biometric"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Biometric Login"
                    android:padding="22dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_fingerprint"
                    android:tint="@color/primary"
                    android:visibility="invisible" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/keypad_key_bg" android:elevation="2dp"/>
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:text="0" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </FrameLayout>
            <FrameLayout android:layout_width="80dp" android:layout_height="80dp"
                android:layout_marginHorizontal="6dp">
                <ImageButton
                    android:id="@+id/btn_delete"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Delete"
                    android:padding="24dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_backspace"
                    android:tint="@color/text_secondary" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
