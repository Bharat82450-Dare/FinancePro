<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/bottom_padding">

            <!-- Premium 3-stop gradient header -->
            <View
                android:id="@+id/header_bg"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/gradient_header_bg"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Greeting row -->
            <TextView
                android:id="@+id/greeting_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="44dp"
                android:text="Welcome Back,"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.02"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btn_sync"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="2dp"
                android:text="Financial Guru"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:fontFamily="sans-serif-black"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btn_sync"
                app:layout_constraintTop_toBottomOf="@+id/greeting_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sync"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Sync"
                android:textColor="#DDFFFFFF"
                android:textSize="13sp"
                app:icon="@drawable/ic_sync"
                app:iconTint="#DDFFFFFF"
                app:iconSize="18dp"
                app:layout_constraintBottom_toBottomOf="@+id/user_name"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/greeting_text" />

            <!-- Balance card — overlapping gradient with deep elevation -->
            <LinearLayout
                android:id="@+id/balance_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="154dp"
                android:background="@drawable/clay_card_bg"
                android:elevation="18dp"
                android:orientation="vertical"
                android:padding="22dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TOTAL BALANCE"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12" />

                    <!-- Set balance pill button -->
                    <LinearLayout
                        android:id="@+id/btn_set_balance_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/pill_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/btn_set_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set Balance"
                            android:textSize="11sp"
                            android:textColor="@color/primary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/total_balance_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="₹0.00"
                    android:textColor="@color/text_primary"
                    android:textSize="38sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/balanceBadgeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Calculated"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider" />

                <!-- Income / Expense row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Income icon pill -->
                        <LinearLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/circle_background"
                            android:gravity="center">
                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@color/income" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Income"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif" />

                            <TextView
                                android:id="@+id/income_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textColor="@color/income"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp">

                        <!-- Expense icon pill -->
                        <LinearLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/circle_background"
                            android:gravity="center">
                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@color/expense" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Expense"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif" />

                            <TextView
                                android:id="@+id/expense_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textColor="@color/expense"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Monthly Budget Progress Card -->
            <LinearLayout
                android:id="@+id/budgetProgressCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:background="@drawable/clay_card_bg"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@+id/balance_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="MONTHLY BUDGET"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/budgetProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% used"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/budgetProgressSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="₹0 of ₹10,000"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black" />

                <ProgressBar
                    android:id="@+id/budgetProgressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_height"
                    android:layout_marginTop="14dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/surface_variant" />
            </LinearLayout>

            <!-- Tracking Card -->
            <LinearLayout
                android:id="@+id/trackingCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:background="@drawable/clay_card_bg"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@+id/budgetProgressCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/trackingIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="?"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/trackingStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Status"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/savingsProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Saved ₹0"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <ProgressBar
                    android:id="@+id/savingsProgressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_height"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progressTint="@color/income"
                    android:progressBackgroundTint="@color/surface_variant" />

                <TextView
                    android:id="@+id/expenseProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Spent ₹0"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <ProgressBar
                    android:id="@+id/expenseProgressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/progress_height"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progressTint="@color/expense"
                    android:progressBackgroundTint="@color/surface_variant" />

                <TextView
                    android:id="@+id/projectedBalanceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Projected: ₹0"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Goals mini-card -->
            <LinearLayout
                android:id="@+id/goalsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:background="@drawable/clay_card_bg"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@+id/trackingCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SAVINGS GOALS"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/viewAllGoalsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/goalItem1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/goal1Name"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Goal 1"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/goal1Amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0/₹0"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/goal1Progress"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/progress_height_thin"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/surface_variant" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/goalItem2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/goal2Name"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Goal 2"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/goal2Amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0/₹0"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/goal2Progress"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/progress_height_thin"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progressTint="@color/accent"
                        android:progressBackgroundTint="@color/surface_variant" />
                </LinearLayout>
            </LinearLayout>

            <!-- Spending Trends section header -->
            <LinearLayout
                android:id="@+id/chart_header_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@+id/goalsCard">

                <TextView
                    android:id="@+id/chart_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Spending Trends"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chart_card"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/clay_card_bg"
                android:elevation="6dp"
                android:padding="@dimen/card_padding_sm"
                app:layout_constraintTop_toBottomOf="@+id/chart_header_row">

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/spending_chart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>

            <!-- Recent Transactions header -->
            <LinearLayout
                android:id="@+id/history_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@+id/chart_card">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Transactions"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/see_all_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See All"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recent_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/history_header"
                tools:listitem="@layout/item_transaction" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/add_transaction_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Add New"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-medium"
        android:textSize="14sp"
        app:icon="@drawable/ic_plus"
        app:iconTint="@color/white"
        app:backgroundTint="@color/primary"
        app:elevation="@dimen/elevation_fab"
        app:cornerRadius="20dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
