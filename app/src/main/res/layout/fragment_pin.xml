<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/pin_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="Enter PIN"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/pin_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Authenticate to access your finances"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pin_title" />

    <!-- PIN dots -->
    <LinearLayout
        android:id="@+id/pin_indicator_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pin_subtitle">

        <View
            android:id="@+id/dot1"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/dot_off" />
        <View
            android:id="@+id/dot2"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/dot_off" />
        <View
            android:id="@+id/dot3"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/dot_off" />
        <View
            android:id="@+id/dot4"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/dot_off" />

    </LinearLayout>

    <!-- Keypad -->
    <LinearLayout
        android:id="@+id/keypad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pin_indicator_container"
        app:layout_constraintVertical_bias="0.7">

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="1" android:textSize="22sp" android:textColor="@color/text_primary" />
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="2" android:textSize="22sp" android:textColor="@color/text_primary" />
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="3" android:textSize="22sp" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="4" android:textSize="22sp" android:textColor="@color/text_primary" />
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="5" android:textSize="22sp" android:textColor="@color/text_primary" />
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="6" android:textSize="22sp" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="7" android:textSize="22sp" android:textColor="@color/text_primary" />
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="8" android:textSize="22sp" android:textColor="@color/text_primary" />
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="9" android:textSize="22sp" android:textColor="@color/text_primary" />
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
            <ImageButton
                android:id="@+id/btn_biometric"
                android:layout_width="80dp" android:layout_height="80dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Biometric Login"
                android:padding="20dp" android:scaleType="fitCenter"
                android:src="@drawable/ic_fingerprint" android:visibility="invisible" />
            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:text="0" android:textSize="22sp" android:textColor="@color/text_primary" />
            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="80dp" android:layout_height="80dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete"
                android:padding="24dp" android:scaleType="fitCenter"
                android:src="@drawable/ic_backspace" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
