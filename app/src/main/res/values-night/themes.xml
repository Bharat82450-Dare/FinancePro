<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FinancePro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#7A9FF0</item>
        <item name="colorSecondaryVariant">#7A9FF0</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">#000000</item>

        <!-- Surface and Background -->
        <item name="android:windowBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorOnBackground">#FFFFFF</item>
        
        <!-- Material 2 color variants for BottomNav -->
        <item name="colorOnSurfaceVariant" tools:ignore="NewApi">#B0B0B0</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#B0B0B0</item>
    </style>
</resources>